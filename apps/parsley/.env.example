# Convex deployment used by the local AI confirmation runner.
CONVEX_URL=https://your-deployment.convex.cloud

# Must match LOCAL_AI_OPERATOR_TOKEN configured in the target Convex deployment.
LOCAL_AI_OPERATOR_TOKEN=replace-with-shared-operator-token

# Optional local runner overrides.
OLLAMA_MODEL=qwen3.6:35b-a3b-coding-nvfp4
OLLAMA_TIMEOUT_MS=120000

# Optional: enables the Claude Agent SDK runner via metered API billing.
# Leave unset to use the Max subscription credentials written by `claude login`.
ANTHROPIC_API_KEY=

# Optional Claude runner overrides.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=120000
ANTHROPIC_CONCURRENCY=5

# Optional: enables the Codex SDK runner via metered API billing.
# Leave unset to use the local Codex login session.
CODEX_API_KEY=

# Optional Codex runner overrides.
CODEX_MODEL=gpt-5.4-mini
CODEX_TIMEOUT_MS=120000
CODEX_CONCURRENCY=5
