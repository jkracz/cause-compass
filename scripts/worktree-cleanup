#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the script's directory and project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
WORKTREES_DIR="$(dirname "$PROJECT_ROOT")/${PROJECT_NAME}-worktrees"

usage() {
    echo -e "${BLUE}Usage:${NC} $0 [--dry-run]"
    echo ""
    echo "Removes worktrees whose upstream branches have been deleted."
    echo ""
    echo "Arguments:"
    echo "  --dry-run    Show what would be removed without actually removing"
    echo ""
    exit 1
}

# Parse arguments
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            echo -e "${RED}Error:${NC} Unexpected argument: $1"
            usage
            ;;
    esac
done

# Check if worktrees directory exists
if [[ ! -d "$WORKTREES_DIR" ]]; then
    echo -e "${YELLOW}No worktrees directory found at:${NC} $WORKTREES_DIR"
    exit 0
fi

cd "$PROJECT_ROOT"

# Fetch latest from remote and prune deleted branches
echo -e "${BLUE}Fetching from remote and pruning deleted branches...${NC}"
git fetch --prune origin
echo ""

# Get list of worktrees (excluding the main one)
echo -e "${BLUE}Checking worktrees in:${NC} $WORKTREES_DIR"
echo ""

removed_count=0
kept_count=0

for worktree_path in "$WORKTREES_DIR"/*/; do
    # Skip if not a directory
    [[ -d "$worktree_path" ]] || continue

    # Remove trailing slash
    worktree_path="${worktree_path%/}"
    worktree_name="$(basename "$worktree_path")"

    # Get the branch name for this worktree
    branch_name=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

    if [[ -z "$branch_name" || "$branch_name" == "HEAD" ]]; then
        echo -e "  ${YELLOW}⊘${NC} $worktree_name - detached HEAD, skipping"
        ((kept_count++)) || true
        continue
    fi

    # Check if the branch exists on remote
    if git show-ref --verify --quiet "refs/remotes/origin/$branch_name" 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $worktree_name ($branch_name) - upstream exists"
        ((kept_count++)) || true
    else
        # Branch doesn't exist on remote
        if [[ "$DRY_RUN" = true ]]; then
            echo -e "  ${RED}✗${NC} $worktree_name ($branch_name) - upstream deleted, ${YELLOW}would remove${NC}"
        else
            echo -e "  ${RED}✗${NC} $worktree_name ($branch_name) - upstream deleted, removing..."
            git worktree remove --force "$worktree_path"
        fi
        ((removed_count++)) || true
    fi
done

# Summary
echo ""
echo -e "${GREEN}========================================${NC}"
if [[ "$DRY_RUN" = true ]]; then
    echo -e "${YELLOW}Dry run complete${NC}"
    echo ""
    echo -e "Would remove: ${RED}$removed_count${NC} worktree(s)"
    echo -e "Would keep:   ${GREEN}$kept_count${NC} worktree(s)"
else
    echo -e "${GREEN}Cleanup complete${NC}"
    echo ""
    echo -e "Removed: ${RED}$removed_count${NC} worktree(s)"
    echo -e "Kept:    ${GREEN}$kept_count${NC} worktree(s)"
fi
echo -e "${GREEN}========================================${NC}"
