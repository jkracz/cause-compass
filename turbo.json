{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "ORG_DATA",
    "BATCH_DIR",
    "OPENAI_API_KEY",
    "BATCH_SIZE",
    "DATABASE_URL",
    "SEARCH_ENGINE_ID_CC",
    "GOOGLE_SEARCH_API_KEY_CC",
    "SEARCH_ENGINE_ID_PERSONAL",
    "GOOGLE_SEARCH_API_KEY_PERSONAL",
    "SEARCH_ENGINE_ID_JKRACZ",
    "GOOGLE_SEARCH_API_KEY_JKRACZ",
    "SEARCH_ENGINE_ID_SF",
    "GOOGLE_SEARCH_API_KEY_SF",
    "SEARCH_ENGINE_ID_JK",
    "GOOGLE_SEARCH_API_KEY_JK",
    "ENABLE_BATCH_CRON",
    "ENABLE_CRAWL_CRON",
    "ENABLE_SEARCH_CRON",
    "OPENAI_WEBHOOK_SECRET",
    "WORKER_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.mjs",
        "!dist/**",
        "eslint.config.*",
        "tsconfig.json"
      ]
    },
    "typecheck": {
      "dependsOn": [],
      "inputs": ["**/*.ts", "**/*.tsx", "!dist/**", "tsconfig.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
