{
    "name": "np-data-parser",
    "version": "1.0.0",
    "description": "Originally built for defining the DB schema and importing nonprofit data from the IRS.",
    "main": "index.js",
    "scripts": {
        "start": "tsx src/index.ts",
        "insert-ntee-file": "tsx src/insertNteeFileIntoDb.ts",
        "insert-eo-file": "tsx src/insertEoFileIntoDb.ts",
        "introspect": "drizzle-kit introspect:pg",
        "migrations:generate": "drizzle-kit generate:pg",
        "migrations:push": "node -r esbuild-register src/lib/db/migrate.ts",
        "db:push": "drizzle-kit push:pg",
        "db:studio": "drizzle-kit studio",
        "migrations:drop": "drizzle-kit drop --config=drizzle.config.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CauseCompass/np-data-parser.git"
    },
    "author": "Joseph Kracz",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/CauseCompass/np-data-parser/issues"
    },
    "homepage": "https://github.com/CauseCompass/np-data-parser#readme",
    "dependencies": {
        "@planetscale/database": "^1.18.0",
        "@supabase/supabase-js": "^2.43.4",
        "axios": "^1.7.2",
        "csv-parse": "^5.5.6",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.31.1",
        "googleapis": "^139.0.0",
        "mongodb": "^6.7.0",
        "openai": "^4.48.1",
        "postgres": "^3.4.4",
        "puppeteer": "^22.10.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.2",
        "drizzle-kit": "^0.22.2",
        "mysql2": "^3.10.0",
        "tsx": "^4.11.2"
    }
}
