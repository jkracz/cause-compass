{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "ORG_DATA",
    "BATCH_DIR",
    "OPENAI_API_KEY",
    "BATCH_SIZE",
    "MONGO_USER",
    "MONGO_PASSWORD",
    "MONGODB_URI",
    "DATABASE_URL",
    "SEARCH_ENGINE_ID_CC",
    "GOOGLE_SEARCH_API_KEY_CC",
    "SEARCH_ENGINE_ID_PERSONAL",
    "GOOGLE_SEARCH_API_KEY_PERSONAL",
    "SEARCH_ENGINE_ID_JKRACZ",
    "GOOGLE_SEARCH_API_KEY_JKRACZ",
    "SEARCH_ENGINE_ID_SF",
    "GOOGLE_SEARCH_API_KEY_SF",
    "SEARCH_ENGINE_ID_JK",
    "GOOGLE_SEARCH_API_KEY_JK"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.mjs", "eslint.config.*", "tsconfig.json"]
    },
    "check-types": {
      "dependsOn": [],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
