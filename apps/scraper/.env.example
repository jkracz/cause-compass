# Convex deployment URL (e.g., https://your-deployment.convex.site)
CONVEX_SITE_URL=

# Shared secret for worker auth (must match Convex WORKER_TOKEN env var)
WORKER_TOKEN=

# Worker identification
WORKER_ID=html-worker-1

# Concurrency (number of parallel fetch slots)
CONCURRENCY=20

# Poll interval when no jobs available (ms)
POLL_INTERVAL_MS=2000

# Per-domain throttle delay (ms)
DOMAIN_THROTTLE_MS=2000

# Health reporter + healthcheck settings
WORKER_HEALTH_FILE=/tmp/worker.health.json
HEALTH_UPDATE_MS=10000
HEALTH_MAX_AGE_MS=120000

# Browser worker settings
BROWSER_HEADLESS=true
BROWSER_NAV_TIMEOUT_MS=45000
BROWSER_WAIT_AFTER_LOAD_MS=1500
