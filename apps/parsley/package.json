{
    "name": "np-data-parser",
    "version": "1.0.0",
    "description": "Originally built for defining the DB schema and importing nonprofit data from the IRS.",
    "main": "index.js",
    "scripts": {
        "start": "tsx src/index.ts",
        "create-profiles": "tsx src/scripts/createOrgsByState.ts",
        "search-orgs": "tsx src/scripts/googleSearchOrgs.ts",
        "introspect": "drizzle-kit introspect",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "migrations:drop": "drizzle-kit drop --config=drizzle.config.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CauseCompass/np-data-parser.git"
    },
    "author": "Joseph Kracz",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/CauseCompass/np-data-parser/issues"
    },
    "homepage": "https://github.com/CauseCompass/np-data-parser#readme",
    "dependencies": {
        "@supabase/supabase-js": "^2.45.0",
        "axios": "^1.7.3",
        "crawlee": "^3.11.1",
        "csv-parse": "^5.5.6",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.32.2",
        "googleapis": "^140.0.1",
        "mongo": "^0.1.0",
        "nanoid": "^5.0.7",
        "openai": "^4.54.0",
        "playwright": "^1.46.0",
        "postgres": "^3.4.4",
        "slugify": "^1.6.6",
        "title-case": "^4.3.1",
        "tldts": "^6.1.38",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@types/node": "^22.1.0",
        "drizzle-kit": "^0.23.2",
        "tsx": "^4.16.5"
    }
}
